{
  "$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "semicolons": "asNeeded"
    }
  },
  "files": {
    "include": [
      "scripts/**/*.jsx",
      "mcp/**/*.js",
      "mcp/**/*.json",
      ".claude/settings.json",
      ".mcp.json",
      ".vscode/settings.json",
      ".vscode/extensions.json",
      "package.json"
    ]
  }
}
