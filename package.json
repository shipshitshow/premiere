{
  "name": "premiere-dev-tools",
  "private": true,
  "version": "0.0.0",
  "description": "Repo-level developer tooling for formatting and git hooks",
  "scripts": {
    "format": "biome format --write .",
    "format:check": "biome check .",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,jsx,json,jsonc}": ["biome format --write"]
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.10"
  },
  "packageManager": "bun@1.2.13"
}
